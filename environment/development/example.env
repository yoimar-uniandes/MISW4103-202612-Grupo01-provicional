# ┌──────────────────────────────────────────────────────────────────────────────┐
# │  Ghost Blog Service — Development Environment                              │
# │  Copy this file to .env and fill in the required values.                   │
# │  cp example.env .env                                                       │
# └──────────────────────────────────────────────────────────────────────────────┘

# ── Node Environment ──────────────────────────────────────────────────────────
NODE_ENV=development

# ── Ghost Configuration ───────────────────────────────────────────────────────
GHOST_IMAGE=ghost:5.130.6-alpine
GHOST_PORT=2368
GHOST_URL=http://localhost:2368

# ── MySQL Configuration ──────────────────────────────────────────────────────
MYSQL_IMAGE=mysql:8.0
MYSQL_ROOT_PASSWORD=ghost_root_dev_password
MYSQL_DATABASE=ghost_dev
MYSQL_USER=ghost_user
MYSQL_PASSWORD=ghost_dev_password

# ── Volumes (host paths) ─────────────────────────────────────────────────────
GHOST_CONTENT_PATH=./volumes/ghost/content
MYSQL_DATA_PATH=./volumes/mysql/data

# ── Mail (optional — disabled by default in development) ─────────────────────
# MAIL_TRANSPORT=SMTP
# MAIL_HOST=smtp.example.com
# MAIL_PORT=587
# MAIL_SECURE=true
# MAIL_USER=your-email@example.com
# MAIL_PASSWORD=your-email-password
# MAIL_FROM='Ghost Blog <noreply@example.com>'
