# ┌──────────────────────────────────────────────────────────────────────────────┐
# │  Ghost Blog Service — Production Environment                               │
# │  Copy this file to .env and fill in ALL required values.                   │
# │  cp example.env .env                                                       │
# │                                                                            │
# │  ⚠  NEVER commit the .env file to version control.                        │
# │  ⚠  Use strong, unique passwords for all credentials.                     │
# └──────────────────────────────────────────────────────────────────────────────┘

# ── Node Environment ──────────────────────────────────────────────────────────
NODE_ENV=production

# ── Ghost Configuration ───────────────────────────────────────────────────────
GHOST_IMAGE=ghost:5.130.6-alpine
GHOST_PORT=2368
# REQUIRED — your public URL (e.g. https://blog.yourdomain.com)
GHOST_URL=https://blog.yourdomain.com

# ── MySQL Configuration ──────────────────────────────────────────────────────
MYSQL_IMAGE=mysql:8.0
# REQUIRED — use strong passwords generated with: openssl rand -base64 32
MYSQL_ROOT_PASSWORD=
MYSQL_DATABASE=ghost_prod
MYSQL_USER=ghost_user
MYSQL_PASSWORD=

# ── Volumes (host paths) ─────────────────────────────────────────────────────
GHOST_CONTENT_PATH=./volumes/ghost/content
MYSQL_DATA_PATH=./volumes/mysql/data

# ── Backup Configuration ─────────────────────────────────────────────────────
BACKUP_PATH=./backups
BACKUP_RETENTION_DAYS=30

# ── Mail (REQUIRED for production — newsletters, invitations, etc.) ──────────
MAIL_TRANSPORT=SMTP
MAIL_HOST=smtp.example.com
# Use port 587 with MAIL_SECURE=false (STARTTLS) or port 465 with MAIL_SECURE=true (SSL).
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=your-email@example.com
MAIL_PASSWORD=your-email-password
MAIL_FROM='Ghost Blog <noreply@yourdomain.com>'
